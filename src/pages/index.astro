---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection.jsx';
import Footer from '../components/Footer.astro';

const mandirs = [
  { logo: 'https://picsum.photos/200/80?random=1' },
  { logo: 'https://picsum.photos/200/80?random=2' },
  { logo: 'https://picsum.photos/200/80?random=3' },
  { logo: 'https://picsum.photos/200/80?random=4' },
  { logo: 'https://picsum.photos/200/80?random=5' },
  { logo: 'https://picsum.photos/200/80?random=6' },
];
---

<Layout title="MandirSol - Donations with Verifiable Records & NFT Rewards">
  <HeroSection client:load />

  <section class="py-20 overflow-hidden bg-white">
    <div class="text-center mb-14">
      <h2 class="text-black uppercase tracking-widest text-base font-semibold">
        Trusted by Thousands of Mandirs
      </h2>
    </div>

    <div class="relative w-full overflow-hidden">
      <div class="absolute left-0 top-0 h-full w-32 bg-linear-to-r from-white to-transparent z-10 pointer-events-none"></div>
      <div class="absolute right-0 top-0 h-full w-32 bg-linear-to-l from-white to-transparent z-10 pointer-events-none"></div>

      <div class="flex w-max animate-scroll space-x-24 items-center">
        {[...mandirs, ...mandirs, ...mandirs].map((mandir, i) => (
          <img src={mandir.logo} class="h-24 object-contain grayscale hover:grayscale-0 opacity-70 hover:opacity-100 hover:scale-110 transition duration-300" alt="mandir logo" key={i} />
        ))}
      </div>
    </div>
   </section>



   <section class="bg-neutral-100 py-24 px-6">
    <div class="max-w-6xl mx-auto text-center">
      <h1 class="text-4xl md:text-6xl font-bold text-gray-900 leading-tight">
        Designed for
        <span class="bg-primary text-white px-4 py-1">Mandirs</span>
        <br />
        not for
        <span class="underline decoration-wavy decoration-secondary underline-offset-20">
          middlemen
        </span>.
      </h1>

      <div class="mt-20 grid md:grid-cols-2 gap-12 text-left">
        <div class="flex items-start gap-5">
          <div class="shrink-0 w-10 h-10 rounded-full border-2 border-gray-800 flex items-center justify-center">
            <svg class="w-5 h-5 text-gray-800" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <p class="text-lg text-gray-600">
            We don't call them "donors" or transactions. They are your
            <span class="font-semibold text-gray-900">devotees.</span>
          </p>
        </div>

        <div class="flex items-start gap-5">
          <div class="shrink-0 w-10 h-10 rounded-full border-2 border-gray-800 flex items-center justify-center">
            <svg class="w-5 h-5 text-gray-800" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <p class="text-lg text-gray-600">
            You have
            <span class="font-semibold text-gray-900">100% ownership</span>
            of your devotee data. Export anytime. We never contact them.
          </p>
        </div>

        <div class="flex items-start gap-5">
          <div class="shrink-0 w-10 h-10 rounded-full border-2 border-gray-800 flex items-center justify-center">
            <svg class="w-5 h-5 text-gray-800" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <p class="text-lg text-gray-600">
            Mandir committees can
            <span class="font-semibold text-gray-900">create campaigns easily</span>
            for sewa, renovation, festivals, or annadan.
          </p>
        </div>

        <div class="flex items-start gap-5">
          <div class="shrink-0 w-10 h-10 rounded-full border-2 border-gray-800 flex items-center justify-center">
            <svg class="w-5 h-5 text-gray-800" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <p class="text-lg text-gray-600">
            Receive donations
            <span class="font-semibold text-gray-900">directly to your bank account.</span>
            No long delays. No hidden control.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-white">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-4xl md:text-5xl font-bold text-center text-gray-900 mb-16">
        How It Works
      </h2>

      <div class="grid md:grid-cols-3 gap-12">
        <div class="text-center">
          <div class="w-16 h-16 bg-primary text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">
            1
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Choose a Mandir</h3>
          <p class="text-gray-600">
            Browse verified mandirs and select a campaign or cause you want to support with your donation.
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-primary text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">
            2
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Donate & Record</h3>
          <p class="text-gray-600">
            Pay via <span class="font-semibold text-gray-900">eSewa</span> or <span class="font-semibold text-gray-900">stablecoins</span>. Every donation is stored with verifiable on-chain records.
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-secondary text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">
            3
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Earn NFT Reward</h3>
          <p class="text-gray-600">
            Connect your Solana wallet to mint an NFT as a token of gratitude. <span class="font-semibold">Optional — no wallet? No problem.</span>
          </p>
        </div>
      </div>
    </div>
  </section>

   <section class="py-20 px-6 bg-primary text-primary-content">
     <div class="max-w-4xl mx-auto text-center">
       <h2 class="text-3xl md:text-5xl font-bold mb-6">
         Ready to Support Your Mandir?
       </h2>
       <p class="text-lg mb-10 opacity-90">
         Join thousands of devotees making a difference with transparent, verifiable donations.
       </p>
       <a href="/donate" class="btn btn-secondary btn-lg text-lg rounded-md">
         Start Donating Now
         <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
           <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
         </svg>
       </a>
     </div>
   </section>

   <div class="w-full bg-primary" style="margin-bottom: -2px;">
     <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none" class="w-full block" style="height: 80px; display: block; margin: 0; padding: 0;">
       <path d="M0,60 C200,100 400,20 600,60 C800,100 1000,20 1200,60 L1200,120 L0,120 Z" fill="#111827" style="display: block;"></path>
     </svg>
   </div>

   <Footer />
</Layout>
